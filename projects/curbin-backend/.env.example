# CurbIn Backend Configuration
# Copy to .env and fill in your actual values

PORT=3000
NODE_ENV=development

# Airtable API Configuration
# Get your API key from: https://airtable.com/account/token
# Your base ID is in the URL: https://airtable.com/[BASE_ID]/...
AIRTABLE_API_KEY=your_api_key_here
AIRTABLE_BASE_ID=appYourBaseIdHere

# Google Maps API (optional, for advanced route optimization)
# Get from: https://cloud.google.com/maps-platform
GOOGLE_MAPS_API_KEY=

# Optional: Set to 'production' for deployment
# NODE_ENV=production
